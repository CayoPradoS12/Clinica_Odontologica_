create database clinica;

use clinica;



create table paciente

(

cpf varchar (11) primary key unique not null,

nome varchar (255) not null,

data_nascimento date not null,

endereço varchar (255) not null,

historico_hospitalar varchar(255)

);



create table dentista

(

cro varchar (255) primary key unique not null,

nome varchar (255) not null,

especialidade varchar (255) not null,

telefone varchar (11) unique not null

);



create table consulta

(

id int auto_increment primary key unique,

data_hora datetime not null,

cpf_paciente varchar (11),

cro_dentista varchar (20),

status_consulta varchar(20),

foreign key (cpf_paciente) references paciente(cpf),

foreign key (cro_dentista) references dentista(cro)

);





create table procedimento

(

descricao_servico varchar (255) not null,

codigo int primary key unique not null,

valor decimal(10,2) not null

);



create table consulta_procedimento

(

id_consulta int,

codigo_procedimento int,

valor_pago decimal(10,2) not null,

primary key (id_consulta, codigo_procedimento),

foreign key (id_consulta) references consulta(id),

foreign key (codigo_procedimento) references procedimento(codigo)

);



create table estoque

(

codigo int auto_increment primary key unique,

servico_nome varchar (255) not null,

quantidade int,

validade date not null

);



create table financeiro (

    id int auto_increment primary key,

    tipo enum('Receita', 'Despesa') not null,

    valor decimal(10,2) not null,

    data_vencimento date not null,

    data_pagamento date,

    forma_pagamento varchar(50), 

    status_pagamento varchar(20), 

    id_consulta int,

    descricao varchar(255),

    

    foreign key (id_consulta) references consulta(id) 

        on delete set null

);



create table procedimento_estoque

(

codigo_estoque int,

codigo_servico int,

primary key (codigo_estoque, codigo_servico),

foreign key (codigo_estoque) references estoque(codigo),

foreign key (codigo_servico) references procedimento(codigo)

);
